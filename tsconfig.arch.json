{
  // Node.js-compatible TypeScript config for architecture tests (ts-node, not Karma).
  // Run via: npm run test:arch
  //
  // Why a separate tsconfig:
  //   - base tsconfig.json uses module:ES2022 + moduleResolution:bundler (browser/webpack context)
  //   - ts-node runs in Node.js and requires CommonJS + node resolution
  //   - isolatedModules:false allows full cross-file type analysis
  //
  // Why *.ts (not *.spec.ts):
  //   - Angular's Karma builder (@ngtools/webpack) discovers ALL *.spec.ts files under src/
  //     via its own internal glob, independent of tsconfig.spec.json include/exclude
  //   - Naming the file .ts keeps it invisible to Karma while still matching **/*.ts here
  //   - tsconfig.spec.json also excludes src/test/architecture as an extra safety net
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "isolatedModules": false,
    "types": ["node"],
    "outDir": "./dist/arch"
  },
  "include": ["src/test/architecture/**/*.ts"],
  "exclude": ["node_modules", "cypress"]
}
