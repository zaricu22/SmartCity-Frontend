{
  "name": "smartcityfront",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "setup:env": "node -e \"const fs=require('fs'),p='src/environments/environment.ts';if(!fs.existsSync(p)){fs.mkdirSync('src/environments',{recursive:true});fs.writeFileSync(p,'export const environment = { production: false, apiBaseUrl: \\'http://localhost:8080\\' };\\n');}\"",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "jest",
    "test:mutation": "stryker run",
    "test:arch": "ts-node --project tsconfig.arch.json src/test/architecture/ddd-architecture.ts",
    "lint": "ng lint",
    "serve:ssr:smartcityfront": "node dist/smartcityfront/server/server.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^18.2.0",
    "@angular/common": "^18.2.0",
    "@angular/compiler": "^18.2.0",
    "@angular/core": "^18.2.0",
    "@angular/forms": "^18.2.0",
    "@angular/platform-browser": "^18.2.0",
    "@angular/platform-browser-dynamic": "^18.2.0",
    "@angular/platform-server": "^18.2.0",
    "@angular/router": "^18.2.0",
    "@angular/ssr": "^18.2.21",
    "@fontsource/inter": "^5.2.8",
    "@lucide/angular": "^1.20.0",
    "express": "^4.18.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.10"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.17",
    "@angular/cli": "^18.2.21",
    "@angular/compiler-cli": "^18.2.0",
    "@stryker-mutator/core": "^8.7.1",
    "@stryker-mutator/jest-runner": "^8.7.1",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.0",
    "@types/node": "^18.18.0",
    "angular-eslint": "^21.0.1",
    "eslint": "^9.39.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-preset-angular": "^14.2.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.5.2",
    "typescript-eslint": "^8.46.4"
  }
}
